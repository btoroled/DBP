# ─── Copialo a .env y ajusta para tu entorno ────────────────────────────
# cp .env.example .env

# ─── Postgres ───────────────────────────────────────────────────────────
POSTGRES_DB=streakstudy_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambiame-en-produccion
POSTGRES_PORT=5432

# ─── DB pool (opcional) ─────────────────────────────────────────────────
DB_POOL_MAX=10
DB_POOL_MIN=2

# ─── API ────────────────────────────────────────────────────────────────
API_PORT=8080
JPA_DDL=update
JPA_SHOW_SQL=false

# ─── JWT (OBLIGATORIO cambiar en produccion) ────────────────────────────
# Genera uno con: openssl rand -base64 48
JWT_SECRET=change-me-in-production-this-must-be-at-least-256-bits-long
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=2592000000

# ─── Anthropic AI (opcional, vacio = deshabilitado) ─────────────────────
ANTHROPIC_API_KEY=

# ─── Mail SMTP (opcional, false = solo loguea, no abre conexion) ────────
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=no-reply@streakstudy.com

# ─── Password reset ─────────────────────────────────────────────────────
# FRONTEND_URL debe apuntar al dominio real en produccion
FRONTEND_URL=http://localhost:5173
PASSWORD_RESET_TTL_MIN=30
PASSWORD_RESET_RATE_LIMIT_MAX=5
PASSWORD_RESET_RATE_LIMIT_WINDOW_MIN=60