# ─── Copialo a .env y ajusta para tu entorno ────────────────────────────
# cp .env.example .env

# ─── Postgres ───────────────────────────────────────────────────────────
POSTGRES_DB=streakstudy_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# ─── API ────────────────────────────────────────────────────────────────
API_PORT=8080

# ─── JWT (cambialo en produccion) ───────────────────────────────────────
JWT_SECRET=change-me-in-production-this-must-be-at-least-256-bits-long
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=2592000000
