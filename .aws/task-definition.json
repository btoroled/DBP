{
  "family": "streakstudy-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::761461657164:role/LabRole",
  "taskRoleArn": "arn:aws:iam::761461657164:role/LabRole",
  "containerDefinitions": [{
    "name": "streakstudy-api",
    "image": "761461657164.dkr.ecr.us-east-1.amazonaws.com/btoroled/streakstudy:20260526-231301",
    "essential": true,
    "portMappings": [{ "containerPort": 8080, "protocol": "tcp" }],
    "environment": [
      { "name": "SPRING_PROFILES_ACTIVE", "value": "prod" },
      { "name": "DB_URL", "value": "jdbc:postgresql://streakstudy-db.c1fjd4fs1vqw.us-east-1.rds.amazonaws.com:5432/streakstudy" },
      { "name": "DB_USER", "value": "streakstudy" },
      { "name": "DB_POOL_MAX", "value": "10" },
      { "name": "DB_POOL_MIN", "value": "2" },
      { "name": "JPA_DDL", "value": "update" },
      { "name": "JPA_SHOW_SQL", "value": "false" },
      { "name": "JWT_EXPIRATION_MS", "value": "900000" },
      { "name": "JWT_REFRESH_EXPIRATION_MS", "value": "2592000000" },
      { "name": "MAIL_ENABLED", "value": "true" },
      { "name": "MAIL_HOST", "value": "smtp.gmail.com" },
      { "name": "MAIL_PORT", "value": "587" },
      { "name": "MAIL_FROM", "value": "no-reply@streakstudy.com" },
      { "name": "FRONTEND_URL", "value": "http://localhost:3000" },
      { "name": "PASSWORD_RESET_TTL_MIN", "value": "30" },
      { "name": "PASSWORD_RESET_RATE_LIMIT_MAX", "value": "5" },
      { "name": "PASSWORD_RESET_RATE_LIMIT_WINDOW_MIN", "value": "60" }
    ],
    "secrets": [
      { "name": "DB_PASSWORD", "valueFrom": "arn:aws:ssm:us-east-1:761461657164:parameter/streakstudy/DB_PASSWORD" },
      { "name": "JWT_SECRET", "valueFrom": "arn:aws:ssm:us-east-1:761461657164:parameter/streakstudy/JWT_SECRET" },
      { "name": "ANTHROPIC_API_KEY", "valueFrom": "arn:aws:ssm:us-east-1:761461657164:parameter/streakstudy/ANTHROPIC_API_KEY" },
      { "name": "MAIL_USER", "valueFrom": "arn:aws:ssm:us-east-1:761461657164:parameter/streakstudy/MAIL_USER" },
      { "name": "MAIL_PASSWORD", "valueFrom": "arn:aws:ssm:us-east-1:761461657164:parameter/streakstudy/MAIL_PASSWORD" }
    ],
    "logConfiguration": {
      "logDriver": "awslogs",
      "options": {
        "awslogs-group": "/ecs/streakstudy",
        "awslogs-region": "us-east-1",
        "awslogs-stream-prefix": "ecs",
        "awslogs-create-group": "true"
      }
    },
    "healthCheck": {
      "command": ["CMD-SHELL", "curl -fsS http://localhost:8080/actuator/health || exit 1"],
      "interval": 30,
      "timeout": 5,
      "retries": 3,
      "startPeriod": 60
    }
  }]
}